SERVER_PORT=3000
GARMIN_USERNAME=your_garmin_username
GARMIN_PASSWORD=your_garmin_password
API_KEY=your_api_key

# Garmin cron sync
GARMIN_TOKEN_CACHE_PATH=garmin_token.json
SYNC_INTERVAL_MINUTES=60

# Optional Telegram alerting (leave empty to disable).
# Alerts fire when unattended sync needs a manual re-login (lockout/MFA/block).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=apppass
DB_NAME=garmin_weight_sync
